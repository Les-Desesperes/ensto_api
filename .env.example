PORT=3000
NODE_ENV=development

# MySQL and phpMyAdmin environment variables
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ensto_db
MYSQL_USER=ensto_user
MYSQL_PASSWORD=ensto_pass
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
ENCRYPTION_KEY=default-32-character-secret-key!
PMA_USER=ensto_user
PMA_PASSWORD=ensto_pass

# Swagger/OpenAPI server URLs (comma-separated)
# Examples:
# SWAGGER_SERVERS=http://localhost:3000,http://babylone:3000
# SWAGGER_SERVERS=https://demo.example.com,https://api.example.com
SWAGGER_SERVERS=http://localhost:3000

# Auth/JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
JWT_COOKIE_MAX_AGE_MS=28800000
BCRYPT_SALT_ROUNDS=12

# Database schema sync (dangerous with existing data/indexes)
# Keep false by default to avoid repeated ALTER index creation.
DB_SYNC_ALTER=false

